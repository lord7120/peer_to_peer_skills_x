# 🔧 Node dependencies
node_modules/

# 💥 Runtime or IDE garbage
.DS_Store
*.log
*.tar.gz
*.zip

# 🧱 Build output — keep only dist/public
# We ignore the server output like dist/index.js if using tsx to run the server
dist/index.js
dist/index.js.map

# ✅ DO NOT ignore dist/public — it's needed for deployment!
# (so we don't ignore all of dist/)

# 🧪 TypeScript cache / tooling
*.tsbuildinfo
.vscode/

# 🛠 Vite + Replit temporary files
vite.config.ts.*
.env.local
.env.*.local

# 📦 Optional build or dev folders
server/public/
coverage/
build/
